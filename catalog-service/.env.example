# Local development environment variables for catalog-service
# Copy this file to .env and fill in real values.
# .env is git-ignored; never commit real secrets.

ASPNETCORE_ENVIRONMENT=Local
ASPNETCORE_URLS=http://+:5002

DB_HOST=localhost,1433
DB_NAME=KubeCart_Catalog
DB_USER=sa
DB_PASSWORD=YourStrong@Pass123

JWT_SIGNING_KEY=dev-local-signing-key-change-before-production-32chars
