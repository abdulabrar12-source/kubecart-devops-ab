# Copy this file to .env and fill in your values.
# For local development, leave VITE_API_BASE_URL empty and let the Vite proxy handle routing.
# The proxy in vite.config.js maps each path prefix to the correct service port:
#   /api/auth    → identity-service  (http://localhost:5001)
#   /api/catalog → catalog-service   (http://localhost:5002)
#   /api/orders  → order-service     (http://localhost:5003)
VITE_API_BASE_URL=
