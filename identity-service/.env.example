# Local development environment variables for identity-service
# Copy this file to .env and fill in real values.
# .env is git-ignored; never commit real secrets.

ASPNETCORE_ENVIRONMENT=Local
ASPNETCORE_URLS=http://+:5001

DB_HOST=localhost,1433
DB_NAME=KubeCart_Identity
DB_USER=sa
DB_PASSWORD=YourStrong@Pass123

JWT_SIGNING_KEY=dev-local-signing-key-change-before-production-32chars
APP_ENCRYPTION_KEY=dev-local-encryption-key-change-me
